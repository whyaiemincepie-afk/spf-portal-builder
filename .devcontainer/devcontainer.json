{
  "name": "SPF Portal Builder",
  "image": "mcr.microsoft.com/dotnet/sdk:8.0",
  "forwardPorts": [5000],
  "postCreateCommand": "dotnet restore",
  "postStartCommand": "dotnet run --urls http://0.0.0.0:5000",
  "portsAttributes": {
    "5000": {
      "label": "SPF Portal Builder",
      "onAutoForward": "openBrowser"
    }
  }
}
