@page "/settings"
@rendermode InteractiveServer

<div style="max-width:40rem;">
    <div style="margin-bottom:1.5rem;">
        <h1 class="page-title">Settings</h1>
        <p class="page-subtitle">Configure your SPF connection and portal preferences</p>
    </div>

    <!-- SPF Connection -->
    <div class="widget-card" style="margin-bottom:1.5rem;">
        <h2 class="section-header">SPF Connection</h2>
        <p style="font-size:0.875rem; color:var(--mine-500); margin-bottom:1rem;">Connect to the Safety Platform of the Future to access live safety data from Snowflake and other sources.</p>

        <div style="display:flex; flex-direction:column; gap:1rem;">
            <div>
                <label style="display:block; font-size:0.875rem; font-weight:500; color:var(--mine-700); margin-bottom:0.25rem;">SPF Endpoint URL</label>
                <input type="url" class="input-field" placeholder="https://spf.yourcompany.com/api" @bind="SpfUrl" />
            </div>
            <div>
                <label style="display:block; font-size:0.875rem; font-weight:500; color:var(--mine-700); margin-bottom:0.25rem;">API Key</label>
                <input type="password" class="input-field" placeholder="Enter your SPF API key" @bind="ApiKey" />
                <p style="font-size:0.75rem; color:var(--mine-400); margin-top:0.25rem;">Get your API key from your SPF administrator</p>
            </div>
            <div style="display:flex; align-items:center; gap:0.75rem;">
                <button class="btn btn-secondary" @onclick="TestConnection">Test Connection</button>
                @if (ConnectionStatus == "connected")
                {
                    <span style="font-size:0.875rem; color:var(--safety-600); display:flex; align-items:center; gap:0.25rem;">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Connected
                    </span>
                }
                else if (ConnectionStatus == "failed")
                {
                    <span style="font-size:0.875rem; color:var(--danger-600); display:flex; align-items:center; gap:0.25rem;">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Connection failed
                    </span>
                }
                else if (ConnectionStatus == "testing")
                {
                    <span style="font-size:0.875rem; color:var(--mine-500);">Testing...</span>
                }
            </div>
        </div>
    </div>

    <!-- Mine Site -->
    <div class="widget-card" style="margin-bottom:1.5rem;">
        <h2 class="section-header">Mine Site</h2>
        <div style="display:flex; flex-direction:column; gap:1rem;">
            <div>
                <label style="display:block; font-size:0.875rem; font-weight:500; color:var(--mine-700); margin-bottom:0.25rem;">Site Name</label>
                <input type="text" class="input-field" placeholder="e.g., North Pit Operations" @bind="SiteName" />
            </div>
            <div>
                <label style="display:block; font-size:0.875rem; font-weight:500; color:var(--mine-700); margin-bottom:0.25rem;">Default Data Refresh Interval</label>
                <select class="input-field" @bind="RefreshInterval">
                    <option value="30">Every 30 seconds</option>
                    <option value="60">Every minute</option>
                    <option value="300">Every 5 minutes</option>
                    <option value="900">Every 15 minutes</option>
                </select>
            </div>
        </div>
    </div>

    <button class="btn btn-primary">Save Settings</button>
</div>

@code {
    private string SpfUrl = "";
    private string ApiKey = "";
    private string SiteName = "";
    private int RefreshInterval = 60;
    private string ConnectionStatus = "idle";

    private async Task TestConnection()
    {
        ConnectionStatus = "testing";
        StateHasChanged();
        await Task.Delay(1500); // Simulate connection test
        ConnectionStatus = string.IsNullOrEmpty(SpfUrl) ? "failed" : "connected";
    }
}
