@page "/"
@rendermode InteractiveServer
@inject DashboardService DashboardService
@inject NavigationManager Nav

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
    <div>
        <h1 class="page-title">My Dashboards</h1>
        <p class="page-subtitle">Create and manage your safety dashboards</p>
    </div>
    <button class="btn btn-primary" @onclick="CreateNew">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        New Dashboard
    </button>
</div>

@if (DashboardService.Dashboards.Count == 0)
{
    <div style="text-align:center; padding:4rem 0;">
        <div style="width:64px;height:64px;background:var(--mine-100);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:1rem;">
            <svg width="32" height="32" fill="none" stroke="var(--mine-400)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
        </div>
        <h3 style="font-size:1.125rem; font-weight:500; color:var(--mine-700); margin-bottom:0.5rem;">No dashboards yet</h3>
        <p style="color:var(--mine-500); max-width:28rem; margin:0 auto 1.5rem;">Create your first safety dashboard from scratch or start with a template designed for common mining safety workflows.</p>
        <div style="display:flex; gap:0.75rem; justify-content:center;">
            <button class="btn btn-primary" @onclick="CreateNew">Create from Scratch</button>
            <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("templates")'>Browse Templates</button>
        </div>
    </div>
}
else
{
    <div class="grid grid-3">
        @foreach (var dash in DashboardService.Dashboards)
        {
            <div class="widget-card clickable" @onclick="() => OpenDashboard(dash.Id)">
                <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                    <div>
                        <div style="font-weight:600; color:var(--mine-800);">@dash.Name</div>
                        <div style="font-size:0.875rem; color:var(--mine-500); margin-top:0.25rem;">@(dash.Description ?? "No description")</div>
                    </div>
                    <span class="badge badge-neutral">@dash.Widgets.Count widgets</span>
                </div>
                <div style="margin-top:1rem; display:flex; justify-content:space-between; font-size:0.75rem; color:var(--mine-400);">
                    <span>Updated @dash.UpdatedAt.ToString("MMM dd")</span>
                    <span style="color:var(--safety-600);">Open →</span>
                </div>
            </div>
        }
    </div>
}

@code {
    private void CreateNew()
    {
        var id = DashboardService.CreateDashboard("Untitled Dashboard");
        Nav.NavigateTo($"designer/{id}");
    }

    private void OpenDashboard(Guid id)
    {
        Nav.NavigateTo($"designer/{id}");
    }
}
