@page "/data"
@rendermode InteractiveServer

<div style="margin-bottom:1.5rem;">
    <h1 class="page-title">Data Explorer</h1>
    <p class="page-subtitle">Browse and query safety data from SPF. Preview data before adding it to your dashboards.</p>
</div>

<!-- Search -->
<div style="display:flex; gap:0.75rem; margin-bottom:1.5rem;">
    <input type="text" class="input-field" placeholder="Search across all safety data..." @bind="SearchQuery" style="flex:1;" />
    <button class="btn btn-secondary">Filters</button>
    <button class="btn btn-secondary">Export</button>
</div>

<!-- Data sources -->
<div class="grid grid-3">
    @foreach (var source in dataSources)
    {
        <div class="widget-card clickable @(SelectedSource == source.Id ? "selected" : "")"
             style="@(SelectedSource == source.Id ? "outline: 2px solid var(--safety-500); outline-offset:-1px;" : "")"
             @onclick="() => SelectedSource = source.Id">
            <div style="display:flex; align-items:center; gap:0.75rem;">
                <div style="background:var(--mine-100); padding:0.5rem; border-radius:0.5rem; display:flex;">
                    <svg width="20" height="20" fill="none" stroke="var(--mine-600)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
                </div>
                <div>
                    <div style="font-weight:600; color:var(--mine-800);">@source.Name</div>
                    <div style="font-size:0.75rem; color:var(--mine-500);">@source.Records.ToString("N0") records · Synced @source.LastSync</div>
                </div>
            </div>
        </div>
    }
</div>

@if (SelectedSource != null)
{
    <div class="widget-card" style="margin-top:1.5rem;">
        <h3 class="section-header">Data Preview: @(dataSources.First(s => s.Id == SelectedSource).Name)</h3>
        <div style="text-align:center; padding:2rem; color:var(--mine-400);">
            <p>Connect to SPF to preview live data</p>
            <p style="font-size:0.875rem; margin-top:0.25rem;">Configure your SPF connection in Settings</p>
        </div>
    </div>
}

@code {
    private string SearchQuery = "";
    private string? SelectedSource;

    private record DataSource(string Id, string Name, int Records, string LastSync);

    private readonly List<DataSource> dataSources = new()
    {
        new("incidents", "Safety Incidents", 2847, "2 min ago"),
        new("inspections", "Inspections", 1253, "5 min ago"),
        new("hazards", "Hazard Assessments", 892, "3 min ago"),
        new("equipment", "Equipment & Certs", 456, "1 min ago"),
        new("compliance", "Compliance Records", 334, "10 min ago"),
        new("training", "Training Records", 5621, "4 min ago"),
    };
}
