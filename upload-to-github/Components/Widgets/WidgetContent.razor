@switch (Type)
{
    case "kpi-card":
        <div style="display:flex; flex-direction:column; justify-content:space-between; height:100%;">
            <span class="kpi-label">@Title</span>
            <div>
                <div class="kpi-value">24</div>
                <div class="kpi-trend trend-good">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"/></svg>
                    12% fewer than last month
                </div>
            </div>
        </div>
        break;

    case "incident-feed":
        <div style="display:flex; flex-direction:column; height:100%; overflow:hidden;">
            <div style="display:flex; gap:0.5rem; align-items:center; margin-bottom:0.5rem;">
                <svg width="14" height="14" fill="none" stroke="var(--warning-500)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                <span style="font-size:0.75rem; font-weight:500; color:var(--mine-700);">@Title</span>
            </div>
            <div style="flex:1; overflow-y:auto; display:flex; flex-direction:column; gap:0.5rem;">
                <div class="incident-item">
                    <div style="display:flex; justify-content:space-between; gap:0.5rem;">
                        <span class="incident-title">Near miss — loader in exclusion zone</span>
                        <span class="badge badge-warning">MODERATE</span>
                    </div>
                    <div class="incident-meta"><span>15 min ago</span><span>North Pit Level 3</span></div>
                </div>
                <div class="incident-item">
                    <div style="display:flex; justify-content:space-between; gap:0.5rem;">
                        <span class="incident-title">Ground fall detected — seismograph alert</span>
                        <span class="badge badge-danger">SERIOUS</span>
                    </div>
                    <div class="incident-meta"><span>42 min ago</span><span>East Decline</span></div>
                </div>
                <div class="incident-item">
                    <div style="display:flex; justify-content:space-between; gap:0.5rem;">
                        <span class="incident-title">PPE non-compliance observed</span>
                        <span class="badge badge-neutral">MINOR</span>
                    </div>
                    <div class="incident-meta"><span>1 hr ago</span><span>Workshop B</span></div>
                </div>
                <div class="incident-item">
                    <div style="display:flex; justify-content:space-between; gap:0.5rem;">
                        <span class="incident-title">Ventilation fan trip — auto restart</span>
                        <span class="badge badge-blue">NEAR MISS</span>
                    </div>
                    <div class="incident-meta"><span>2 hrs ago</span><span>South Vent Shaft</span></div>
                </div>
            </div>
        </div>
        break;

    case "alert-panel":
        <div style="display:flex; flex-direction:column; height:100%; overflow:hidden;">
            <div style="display:flex; gap:0.5rem; align-items:center; margin-bottom:0.5rem;">
                <svg width="14" height="14" fill="none" stroke="var(--danger-500)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                <span style="font-size:0.75rem; font-weight:500; color:var(--mine-700);">@Title</span>
                <span class="badge badge-danger">3</span>
            </div>
            <div style="flex:1; overflow-y:auto; display:flex; flex-direction:column; gap:0.5rem;">
                <div class="alert-item alert-high">
                    <div class="alert-text">Cert expired: Crane #4 inspection overdue</div>
                    <div class="alert-time">5 min ago</div>
                </div>
                <div class="alert-item alert-medium">
                    <div class="alert-text">Training: 3 workers with expired confined space cert</div>
                    <div class="alert-time">1 hr ago</div>
                </div>
                <div class="alert-item alert-medium">
                    <div class="alert-text">Inspection overdue: East Decline pre-shift</div>
                    <div class="alert-time">2 hrs ago</div>
                </div>
            </div>
        </div>
        break;

    case "compliance-gauge":
        <div class="gauge-container">
            <span class="kpi-label">@Title</span>
            <svg width="96" height="96" viewBox="0 0 36 36" style="margin:0.75rem 0;">
                <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e2e8f0" stroke-width="3"/>
                <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#16a34a" stroke-width="3" stroke-dasharray="87, 100" stroke-linecap="round"/>
                <text x="18" y="20.5" text-anchor="middle" font-size="7" font-weight="700" fill="var(--mine-800)">87%</text>
            </svg>
            <span style="font-size:0.75rem; color:var(--mine-400);">On track</span>
        </div>
        break;

    case "equipment-status":
        <div style="display:flex; flex-direction:column; height:100%;">
            <span style="font-size:0.75rem; font-weight:500; color:var(--mine-700); margin-bottom:0.75rem;">@Title</span>
            <div style="display:flex; flex-direction:column; gap:0.5rem;">
                <div class="eq-item"><span class="eq-name">Haul Truck #7</span><span class="badge badge-safety">Operational</span></div>
                <div class="eq-item"><span class="eq-name">Crane #4</span><span class="badge badge-danger">Needs Maintenance</span></div>
                <div class="eq-item"><span class="eq-name">Drill Rig #2</span><span class="badge badge-safety">Operational</span></div>
                <div class="eq-item"><span class="eq-name">Loader #5</span><span class="badge badge-warning">Under Maintenance</span></div>
            </div>
        </div>
        break;

    case "expiry-alerts":
        <div style="display:flex; flex-direction:column; height:100%;">
            <span style="font-size:0.75rem; font-weight:500; color:var(--mine-700); margin-bottom:0.75rem;">@Title</span>
            <div style="display:flex; flex-direction:column; gap:0.5rem;">
                <div style="padding:0.5rem; background:var(--danger-50); border-radius:0.25rem;">
                    <div style="font-size:0.75rem; font-weight:500; color:var(--mine-800);">John Smith — Confined Space</div>
                    <div style="font-size:0.625rem; color:var(--danger-600);">Expired 15 days ago</div>
                </div>
                <div style="padding:0.5rem; background:var(--warning-50); border-radius:0.25rem;">
                    <div style="font-size:0.75rem; font-weight:500; color:var(--mine-800);">Mike Brown — Working at Heights</div>
                    <div style="font-size:0.625rem; color:var(--warning-600);">Expires in 5 days</div>
                </div>
                <div style="padding:0.5rem; background:var(--warning-50); border-radius:0.25rem;">
                    <div style="font-size:0.75rem; font-weight:500; color:var(--mine-800);">Lisa Chen — Gas Monitoring</div>
                    <div style="font-size:0.625rem; color:var(--warning-600);">Expires in 12 days</div>
                </div>
            </div>
        </div>
        break;

    default:
        <div style="display:flex; align-items:center; justify-content:center; height:100%; background:var(--mine-50); border-radius:0.5rem;">
            <span style="font-size:0.75rem; color:var(--mine-400);">@Type widget — connect SPF for live data</span>
        </div>
        break;
}

@code {
    [Parameter] public string Type { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
}
