@rendermode InteractiveServer

<div class="modal-overlay" @onclick="OnClose">
    <div class="modal-content" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h2 style="font-size:1.125rem; font-weight:600; color:var(--mine-800);">Add Widget</h2>
            <button class="btn btn-sm" style="padding:0.25rem;" @onclick="OnClose">
                <svg width="20" height="20" fill="none" stroke="var(--mine-500)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="modal-body">
            @foreach (var cat in categories)
            {
                <div style="margin-bottom:1.5rem;">
                    <h3 style="font-size:0.75rem; font-weight:600; color:var(--mine-600); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.75rem;">@cat.Name</h3>
                    <div class="grid grid-3" style="gap:0.75rem;">
                        @foreach (var w in cat.Widgets)
                        {
                            <button style="display:flex; align-items:flex-start; gap:0.75rem; padding:0.75rem; border-radius:0.5rem; border:1px solid var(--mine-200); background:white; cursor:pointer; text-align:left; transition:all 0.15s;"
                                    @onclick="() => Select(w.Type)"
                                    onmouseover="this.style.borderColor='var(--safety-400)';this.style.background='var(--safety-50)'"
                                    onmouseout="this.style.borderColor='var(--mine-200)';this.style.background='white'">
                                <div>
                                    <div style="font-size:0.875rem; font-weight:500; color:var(--mine-800);">@w.Name</div>
                                    <div style="font-size:0.75rem; color:var(--mine-400);">@w.Description</div>
                                </div>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnSelect { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private void Select(string type) => OnSelect.InvokeAsync(type);

    private record WidgetInfo(string Type, string Name, string Description);
    private record Category(string Name, List<WidgetInfo> Widgets);

    private readonly List<Category> categories = new()
    {
        new("Incidents", new()
        {
            new("incident-feed", "Incident Feed", "Live feed of recent incidents"),
            new("incident-chart", "Incident Chart", "Incidents over time"),
            new("incident-table", "Incident Table", "Searchable incident list"),
            new("severity-gauge", "Severity Gauge", "Severity breakdown"),
        }),
        new("Hazards", new()
        {
            new("hazard-map", "Hazard Map", "Spatial hazard visualization"),
            new("alert-panel", "Alert Panel", "Active hazard alerts"),
        }),
        new("Compliance", new()
        {
            new("compliance-gauge", "Compliance Status", "Overall compliance %"),
            new("obligation-table", "Obligations Table", "Regulatory obligations"),
            new("audit-calendar", "Audit Calendar", "Upcoming audits"),
        }),
        new("Equipment", new()
        {
            new("equipment-status", "Equipment Status", "Fleet condition overview"),
            new("maintenance-calendar", "Maintenance Calendar", "Maintenance schedule"),
            new("cert-expiry", "Cert Expiry", "Expiring certifications"),
        }),
        new("Training", new()
        {
            new("training-matrix", "Training Matrix", "Crew competency matrix"),
            new("expiry-alerts", "Expiry Alerts", "Expiring training"),
            new("completion-chart", "Completion Rate", "Training completion %"),
        }),
        new("General", new()
        {
            new("kpi-card", "KPI Card", "Single metric display"),
            new("action-list", "Action List", "Outstanding actions"),
        }),
    };
}
